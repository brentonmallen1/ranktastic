# ============================================================
# Ranktastic Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------

# Secret key for signing JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# openssl rand -base64 32  
SECRET_KEY=change-me-to-a-random-secret-key

# Admin credentials (used on first run to create the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ------------------------------------------------------------
# NETWORK
# ------------------------------------------------------------

# Port exposed on the host
PORT=8080

# Public base URL — used in share links and email links.
# Set this to your actual domain in production.
BASE_URL=http://localhost:8080

# ------------------------------------------------------------
# DATA STORAGE
# ------------------------------------------------------------

# Host path for the SQLite database and persistent data.
# This directory is mounted into the container at /data.
# For Unraid, set this to your appdata location, e.g.:
#   DATA_PATH=/mnt/user/appdata/ranktastic
DATA_PATH=./data

# ------------------------------------------------------------
# ACCESS CONTROL
# ------------------------------------------------------------

# Allow anyone to create polls (not just the admin).
# Set to false to restrict poll creation to the admin only.
ALLOW_PUBLIC_POLLS=true

# ------------------------------------------------------------
# EMAIL (optional — required for vote verification and result notifications)
# ------------------------------------------------------------

EMAIL_ENABLED=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ranktastic.local

# Set to false if your SMTP server uses plain SMTP (no TLS/STARTTLS)
SMTP_TLS=true

# ------------------------------------------------------------
# DOCKER REGISTRY (for releases)
# ------------------------------------------------------------
# Registry URL for publishing images (e.g., docker.io/username, ghcr.io/username)
DOCKER_REGISTRY=
