<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <!-- Container Metadata -->
  <Name>ranktastic</Name>
  <Repository>registry.mallen.us/ranktastic:latest</Repository>
  <Registry>registry.mallen.us</Registry>
  <Branch>
    <Tag>latest</Tag>
    <TagDescription>Latest stable release</TagDescription>
  </Branch>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Shell>bash</Shell>

  <!-- Application Info -->
  <Support></Support>
  <Project></Project>
  <Overview>Self-hosted ranked polling and voting application. Create polls, rank options, and track results in real-time. Features admin management, optional public polls, and email notifications.</Overview>
  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL></TemplateURL>
  <Icon></Icon>
  <ExtraParams/>
  <Requires/>
  <Date>2026-03-30</Date>
  <Beta>False</Beta>
  <PostArgs/>
  <DonateText/>
  <DonateLink/>
  <DonateImg/>

  <!-- ===== ALWAYS VISIBLE CONFIG ===== -->

  <!-- Port -->
  <Config Name="WebUI Port" Target="80" Default="8080" Mode="tcp"
          Description="Web interface port"
          Type="Port" Display="always" Required="true" Mask="false">8080</Config>

  <!-- Volume Paths -->
  <Config Name="Data Directory" Target="/data" Default="/mnt/user/appdata/ranktastic"
          Mode="rw" Description="Persistent storage for the database and application data"
          Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/ranktastic</Config>

  <!-- Auth -->
  <Config Name="Secret Key" Target="SECRET_KEY" Default=""
          Mode="" Description="Session signing key. Generate with: python -c 'import secrets; print(secrets.token_hex(32))'"
          Type="Variable" Display="always" Required="true" Mask="true"></Config>

  <Config Name="Admin Username" Target="ADMIN_USERNAME" Default="admin"
          Mode="" Description="Username for the admin account"
          Type="Variable" Display="always" Required="false" Mask="false">admin</Config>

  <Config Name="Admin Password" Target="ADMIN_PASSWORD" Default=""
          Mode="" Description="Password for the admin account"
          Type="Variable" Display="always" Required="true" Mask="true"></Config>

  <!-- ===== ADVANCED CONFIG ===== -->

  <!-- Application -->
  <Config Name="Base URL" Target="BASE_URL" Default=""
          Mode="" Description="External URL of the app (e.g. http://192.168.1.100:8080). Used for links in emails and redirects."
          Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="Allow Public Polls" Target="ALLOW_PUBLIC_POLLS" Default="true"
          Mode="" Description="Allow unauthenticated users to view and vote on public polls"
          Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>

  <!-- Email -->
  <Config Name="Email Enabled" Target="EMAIL_ENABLED" Default="false"
          Mode="" Description="Enable email notifications via SMTP"
          Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>

  <Config Name="SMTP Host" Target="SMTP_HOST" Default=""
          Mode="" Description="SMTP server hostname (required if Email Enabled is true)"
          Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="SMTP Port" Target="SMTP_PORT" Default="587"
          Mode="" Description="SMTP server port"
          Type="Variable" Display="advanced" Required="false" Mask="false">587</Config>

  <Config Name="SMTP User" Target="SMTP_USER" Default=""
          Mode="" Description="SMTP authentication username"
          Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="SMTP Password" Target="SMTP_PASSWORD" Default=""
          Mode="" Description="SMTP authentication password"
          Type="Variable" Display="advanced" Required="false" Mask="true"></Config>

  <Config Name="SMTP From" Target="SMTP_FROM" Default="noreply@ranktastic.local"
          Mode="" Description="From address used in outgoing emails"
          Type="Variable" Display="advanced" Required="false" Mask="false">noreply@ranktastic.local</Config>

  <Config Name="SMTP TLS" Target="SMTP_TLS" Default="true"
          Mode="" Description="Use STARTTLS when connecting to the SMTP server"
          Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>

  <!-- Internal -->
  <Config Name="DATA_PATH" Target="DATA_PATH" Default="/data"
          Mode="" Description="Internal data directory path (do not change)"
          Type="Variable" Display="advanced" Required="false" Mask="false">/data</Config>

</Container>
